---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Student Life" description="Discover the vibrant student life at Faith Christian Schools -- clubs, sports, activities, and community.">
  <Header slot="header" />

  <PageHero title="Student Life" breadcrumb="Student Life" backgroundImage="fcs/uploads/zjpkqkraeveq74jelt66" />

  <!-- Activities Grid with Photos -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16 animate-on-scroll">
        <h2 class="section-title">Beyond the Classroom</h2>
        <p class="section-subtitle">
          At Faith Christian Schools, education extends well beyond textbooks. Our students grow through sports, clubs, community service, and enrichment programmes.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        {[
          { title: "Sports & Athletics", description: "Football, athletics, table tennis, and inter-house competitions building teamwork, discipline, and physical fitness.", image: "fcs/uploads/w910dzbfjv2lnuoaerej" },
          { title: "Clubs & Societies", description: "Debate club, science club, literary and drama society, press club, and more. Students explore passions and develop leadership skills.", image: "fcs/uploads/pvouk5azbcemrjmp9zfs" },
          { title: "Christian Fellowship", description: "Weekly chapel services, Bible study groups, and prayer meetings nurturing spiritual growth and building a strong moral foundation.", image: "fcs/uploads/c5va6b40fngpoubsgujx" },
          { title: "Community Service", description: "Students participate in community outreach programmes, learning the value of giving back and making a positive impact.", image: "fcs/uploads/snh1lcpw45rv1pwigt8j" },
          { title: "Cultural Activities", description: "Cultural day celebrations, talent shows, and creative arts exhibitions celebrating Nigeria's rich heritage and student creativity.", image: "fcs/uploads/nxohbzzkadamhmqpc7zq" },
          { title: "Excursions & Field Trips", description: "Educational visits to museums, historical sites, and organisations that bring classroom learning to life.", image: "fcs/uploads/varwtsiarbisgcrex2ee" },
        ].map(item => (
          <div class="bg-cream-light rounded-2xl overflow-hidden shadow-warm card-hover">
            <img
              src={`https://res.cloudinary.com/dgvktekep/image/upload/w_600,h_400,c_fill,q_auto,f_auto/${item.image}.jpg`}
              alt={`${item.title} at Faith Christian Schools`}
              class="w-full h-48 object-cover"
              loading="lazy"
            />
            <div class="p-6">
              <h3 class="font-heading font-bold text-lg text-maroon mb-2">{item.title}</h3>
              <p class="text-text-light text-sm leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Daily Life with Photo -->
  <section class="py-20 bg-cream-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll slide-left">
          <h2 class="section-title">A Day at Faith Christian Schools</h2>
          <div class="space-y-4 mt-8">
            {[
              { time: "7:30 AM", activity: "Arrival and Morning Assembly", detail: "Students gather for devotion, anthem, and announcements" },
              { time: "8:00 AM", activity: "Morning Lessons", detail: "Core subjects including English, Mathematics, and Sciences" },
              { time: "10:30 AM", activity: "Break Time", detail: "Snacks and supervised recreation" },
              { time: "11:00 AM", activity: "Mid-Morning Lessons", detail: "Continued academic sessions and practical work" },
              { time: "1:00 PM", activity: "Lunch Break", detail: "Lunch and afternoon recreation" },
              { time: "2:00 PM", activity: "Afternoon Sessions", detail: "Electives, clubs, sports, and enrichment activities" },
              { time: "3:30 PM", activity: "Closing", detail: "Prep time, pick-up, or school bus departure" },
            ].map(item => (
              <div class="flex gap-6 p-4 bg-white rounded-xl shadow-warm">
                <div class="w-20 shrink-0 text-right">
                  <span class="text-maroon font-bold text-sm">{item.time}</span>
                </div>
                <div>
                  <h3 class="font-heading font-bold text-maroon text-sm mb-0.5">{item.activity}</h3>
                  <p class="text-text-muted text-xs">{item.detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="animate-on-scroll slide-right">
          <img
            src="https://res.cloudinary.com/dgvktekep/image/upload/w_800,h_900,c_fill,q_auto,f_auto/fcs/uploads/xelgxjg8lkvqxkgvltv8.jpg"
            alt="Daily school life at Faith Christian Schools"
            class="w-full rounded-2xl shadow-warm-lg h-[600px] object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
