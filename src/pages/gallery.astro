---

<BaseLayout title="Gallery" description="See our campus, facilities, classrooms, and student life at Faith Christian Schools Karu.">
  <Header slot="header" />

  <PageHero title="Gallery" breadcrumb="Gallery" />

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <h2 class="section-title">Life at Faith Christian Schools</h2>
        <p class="section-subtitle">
          Explore our campus, facilities, and the vibrant community that makes Faith Christian Schools a special place to learn and grow.
        </p>
      </div>

      <!-- Gallery Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {galleryImages.map((image) => (
          <div class="group relative aspect-[4/3] rounded-2xl overflow-hidden bg-cream-light border border-cream-dark">
            <img
              src={`https://res.cloudinary.com/dgvktekep/image/upload/w_600,h_450,c_fill,q_auto,f_auto/${image.id}.jpg`}
              alt={image.alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              width="600"
              height="450"
            />
            <div class="absolute inset-0 bg-maroon/0 group-hover:bg-maroon/30 transition-colors duration-300 flex items-end">
              <p class="text-white text-sm font-medium p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                {image.alt}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
