---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';

// Gallery images from 01-RAW/FCS-Web-Photos -- will be replaced with Cloudinary URLs
const galleryImages = [
  { src: "/gallery/placeholder-1.jpg", alt: "School building and campus" },
  { src: "/gallery/placeholder-2.jpg", alt: "Students in classroom" },
  { src: "/gallery/placeholder-3.jpg", alt: "Science laboratory" },
  { src: "/gallery/placeholder-4.jpg", alt: "Computer room" },
  { src: "/gallery/placeholder-5.jpg", alt: "Sports and recreation" },
  { src: "/gallery/placeholder-6.jpg", alt: "School assembly" },
  { src: "/gallery/placeholder-7.jpg", alt: "Library" },
  { src: "/gallery/placeholder-8.jpg", alt: "School events" },
  { src: "/gallery/placeholder-9.jpg", alt: "Playground" },
];
---

<BaseLayout title="Gallery" description="See our campus, facilities, classrooms, and student life at Faith Christian Schools Karu.">
  <Header slot="header" />

  <PageHero title="Gallery" breadcrumb="Gallery" />

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <h2 class="section-title">Life at Faith Christian Schools</h2>
        <p class="section-subtitle">
          Explore our campus, facilities, and the vibrant community that makes Faith Christian Schools a special place to learn and grow.
        </p>
      </div>

      <!-- Gallery Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {galleryImages.map((image, index) => (
          <div class="group relative aspect-[4/3] rounded-2xl overflow-hidden bg-cream-light border border-cream-dark">
            <!-- Placeholder until real images are uploaded to Cloudinary -->
            <div class="absolute inset-0 flex items-center justify-center bg-cream">
              <div class="text-center">
                <svg class="w-12 h-12 text-maroon/20 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span class="text-sm text-text-muted">{image.alt}</span>
              </div>
            </div>
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-maroon/0 group-hover:bg-maroon/30 transition-colors duration-300 flex items-end">
              <p class="text-white text-sm font-medium p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                {image.alt}
              </p>
            </div>
          </div>
        ))}
      </div>

      <!-- Note about photos -->
      <div class="mt-12 p-6 bg-cream-light rounded-2xl border border-cream-dark text-center">
        <p class="text-text-muted text-sm">
          More photos coming soon. We have 58 school photos ready for upload.
        </p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
