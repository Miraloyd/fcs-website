---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';

const galleryImages = [
  { id: "fcs/uploads/friffapsxjid9ik8id81", alt: "Campus life" },
  { id: "fcs/uploads/tsasamswhzlkay6spvcv", alt: "School facilities" },
  { id: "fcs/uploads/qz9las7rxmcljp8ka9bl", alt: "Students and staff" },
  { id: "fcs/uploads/j5vru3kw2td9r107cbdp", alt: "Classroom learning" },
  { id: "fcs/uploads/cbjg8rkhuaockwcbi0tv", alt: "School activities" },
  { id: "fcs/uploads/lldpcgvens2c1msekybu", alt: "Student engagement" },
  { id: "fcs/uploads/z9up9hfja5eids6r8srb", alt: "School community" },
  { id: "fcs/uploads/lezsopo7gbyr0hysrzeq", alt: "Faith Christian Schools" },
  { id: "fcs/uploads/n3uym6pd74rzkentmaz6", alt: "School environment" },
  { id: "fcs/uploads/ubgsgc8rk9z25d5bcqaw", alt: "Campus grounds" },
  { id: "fcs/uploads/jeeo7e0ffjfbbn71xqvo", alt: "Academic excellence" },
  { id: "fcs/uploads/syt0we7qhjrjermh4vyy", alt: "School events" },
  { id: "fcs/uploads/zjpkqkraeveq74jelt66", alt: "Student activities" },
  { id: "fcs/uploads/xelgxjg8lkvqxkgvltv8", alt: "School life" },
  { id: "fcs/uploads/em72ny7dqcfuz3fvkfgs", alt: "Learning environment" },
  { id: "fcs/uploads/am9ovrwzhcuunye65pvt", alt: "Campus view" },
];
---

<BaseLayout title="Gallery" description="See our campus, facilities, classrooms, and student life at Faith Christian Schools Karu.">
  <Header slot="header" />

  <PageHero title="Gallery" breadcrumb="Gallery" />

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <h2 class="section-title">Life at Faith Christian Schools</h2>
        <p class="section-subtitle">
          Explore our campus, facilities, and the vibrant community that makes Faith Christian Schools a special place to learn and grow.
        </p>
      </div>

      <!-- Gallery Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {galleryImages.map((image) => (
          <div class="group relative aspect-[4/3] rounded-2xl overflow-hidden bg-cream-light border border-cream-dark">
            <img
              src={`https://res.cloudinary.com/dgvktekep/image/upload/w_600,h_450,c_fill,q_auto,f_auto/${image.id}.jpg`}
              alt={image.alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              width="600"
              height="450"
            />
            <div class="absolute inset-0 bg-maroon/0 group-hover:bg-maroon/30 transition-colors duration-300 flex items-end">
              <p class="text-white text-sm font-medium p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                {image.alt}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
