---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Contact Us" description="Get in touch with Faith Christian Schools Karu. Visit us, call, email, or send a WhatsApp message.">
  <Header slot="header" />

  <PageHero title="Contact Us" breadcrumb="Contact Us" />

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Contact Information -->
        <div>
          <h2 class="section-title">Get in Touch</h2>
          <p class="section-subtitle">
            We would love to hear from you. Whether you have questions about admissions, our programmes, or would like to schedule a visit, kindly reach out through any of the channels below.
          </p>

          <div class="space-y-6">
            <!-- Address -->
            <div class="flex items-start gap-4 p-5 bg-cream-light rounded-xl border border-cream-dark">
              <div class="w-10 h-10 rounded-lg bg-maroon/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-maroon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-maroon mb-1">Our Address</h3>
                <p class="text-text-light text-sm leading-relaxed">
                  Plot MF 31, ABG Hill,<br />
                  Behind Water Board, Karu,<br />
                  Federal Capital Territory, Nigeria
                </p>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start gap-4 p-5 bg-cream-light rounded-xl border border-cream-dark">
              <div class="w-10 h-10 rounded-lg bg-maroon/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-maroon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-maroon mb-1">Phone</h3>
                <p class="text-text-light text-sm space-y-1">
                  <a href="tel:+2348036012387" class="block hover:text-maroon transition-colors">+234 803 601 2387 (Main)</a>
                  <a href="tel:+2348033406414" class="block hover:text-maroon transition-colors">+234 803 340 6414 (Admissions)</a>
                </p>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4 p-5 bg-cream-light rounded-xl border border-cream-dark">
              <div class="w-10 h-10 rounded-lg bg-maroon/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-maroon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-maroon mb-1">Email</h3>
                <a href="mailto:info@faithchristianschools.net" class="text-text-light text-sm hover:text-maroon transition-colors">
                  info@faithchristianschools.net
                </a>
              </div>
            </div>

            <!-- WhatsApp -->
            <a
              href="https://wa.me/2349113224179"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 p-5 bg-green-50 rounded-xl border border-green-200 hover:bg-green-100 transition-colors"
            >
              <div class="w-10 h-10 rounded-lg bg-green-600 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-green-800 mb-0.5">WhatsApp</h3>
                <p class="text-green-700 text-sm">Chat with us on WhatsApp</p>
              </div>
            </a>

            <!-- Facebook -->
            <a
              href="https://www.facebook.com/share/p/1AMWrKZjMS/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 p-5 bg-blue-50 rounded-xl border border-blue-200 hover:bg-blue-100 transition-colors"
            >
              <div class="w-10 h-10 rounded-lg bg-blue-600 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-blue-800 mb-0.5">Facebook</h3>
                <p class="text-blue-700 text-sm">Follow us on Facebook</p>
              </div>
            </a>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <h2 class="section-title">Send Us a Message</h2>
          <p class="section-subtitle">
            Fill in the form below and we will get back to you as soon as possible.
          </p>

          <form id="contact-form" class="space-y-5" action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value="5730ddd0-e399-4776-9311-869e33e809c0" />
            <input type="hidden" name="subject" value="FCS Website -- New Contact Enquiry" />
            <input type="hidden" name="from_name" value="Faith Christian Schools Website" />
            <input type="checkbox" name="botcheck" class="hidden" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-text mb-1.5">Full Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-cream-dark bg-cream-light text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-maroon/30 focus:border-maroon transition-colors"
                  placeholder="Your full name"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-text mb-1.5">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-4 py-3 rounded-lg border border-cream-dark bg-cream-light text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-maroon/30 focus:border-maroon transition-colors"
                  placeholder="+234 ..."
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-text mb-1.5">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-cream-dark bg-cream-light text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-maroon/30 focus:border-maroon transition-colors"
                placeholder="your.email@example.com"
              />
            </div>

            <div>
              <label for="enquiry" class="block text-sm font-medium text-text mb-1.5">Enquiry Type</label>
              <select
                id="enquiry"
                name="enquiry_type"
                class="w-full px-4 py-3 rounded-lg border border-cream-dark bg-cream-light text-text focus:outline-none focus:ring-2 focus:ring-maroon/30 focus:border-maroon transition-colors"
              >
                <option value="general">General Enquiry</option>
                <option value="admissions">Admissions</option>
                <option value="fees">Fees Information</option>
                <option value="visit">Schedule a Visit</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-text mb-1.5">Message</label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full px-4 py-3 rounded-lg border border-cream-dark bg-cream-light text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-maroon/30 focus:border-maroon transition-colors resize-none"
                placeholder="How can we help you?"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full px-8 py-3.5 bg-maroon text-white font-semibold rounded-lg hover:bg-maroon-dark transition-colors duration-200"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Map -->
  <section class="py-0">
    <div class="w-full h-96 bg-cream">
      <iframe
        src="https://maps.google.com/maps?q=9.0219,7.5618&z=16&output=embed"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Faith Christian Schools location on Google Maps"
      ></iframe>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
