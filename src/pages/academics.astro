---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Academics" description="Explore our dual curriculum: Nigerian (NERDC) and Cambridge International (IGCSE/A-Levels). From Montessori early years to senior secondary.">
  <Header slot="header" />

  <PageHero title="Academics" breadcrumb="Academics" backgroundImage="fcs/uploads/jw3u1zfp6xjeosj84uvp" />

  <!-- Curriculum Overview with Photos -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16 animate-on-scroll">
        <h2 class="section-title">Our Curriculum</h2>
        <p class="section-subtitle">
          We offer a dual curriculum that combines the Nigerian national framework with internationally recognised Cambridge programmes.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16 stagger-children">
        <div class="bg-cream-light rounded-2xl overflow-hidden shadow-warm card-hover">
          <img
            src="https://res.cloudinary.com/dgvktekep/image/upload/w_800,h_300,c_fill,q_auto,f_auto/fcs/uploads/lljnvdtr7vlqpjwas8oj.jpg"
            alt="Classroom learning at Faith Christian Schools"
            class="w-full h-48 object-cover"
            loading="lazy"
          />
          <div class="p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-green-600 flex items-center justify-center">
                <span class="text-white font-bold text-sm">NG</span>
              </div>
              <h3 class="font-heading font-bold text-xl text-maroon">Nigerian Curriculum (NERDC)</h3>
            </div>
            <p class="text-text-light leading-relaxed mb-4">
              Our core curriculum follows the NERDC framework, ensuring students are thoroughly prepared for WAEC and NECO examinations.
            </p>
            <ul class="space-y-2">
              {["English Language", "Mathematics", "Basic Science & Technology", "Social Studies", "Civic Education", "Computer Studies / ICT", "Christian Religious Studies", "Creative Arts"].map(subject => (
                <li class="flex items-center gap-2 text-sm text-text-light">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-500 shrink-0"></span>
                  {subject}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="bg-cream-light rounded-2xl overflow-hidden shadow-warm card-hover">
          <img
            src="https://res.cloudinary.com/dgvktekep/image/upload/w_800,h_300,c_fill,q_auto,f_auto/fcs/uploads/qxwyquwclgbrqexjlbaj.jpg"
            alt="STEM and Cambridge programme at Faith Christian Schools"
            class="w-full h-48 object-cover"
            loading="lazy"
          />
          <div class="p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-blue-600 flex items-center justify-center">
                <span class="text-white font-bold text-sm">CIE</span>
              </div>
              <h3 class="font-heading font-bold text-xl text-maroon">Cambridge International</h3>
            </div>
            <p class="text-text-light leading-relaxed mb-4">
              As a Cambridge International partner school, we offer IGCSE and A-Level programmes that open doors to universities worldwide.
            </p>
            <ul class="space-y-2">
              {["Cambridge IGCSE Subjects", "Cambridge A-Level Programmes", "International Recognition", "Global University Access", "Critical Thinking Skills", "Research & Inquiry Methods", "Practical Laboratory Work", "Extended Projects"].map(item => (
                <li class="flex items-center gap-2 text-sm text-text-light">
                  <span class="w-1.5 h-1.5 rounded-full bg-blue-500 shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Education Levels with Photos -->
  <section class="py-20 bg-cream-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-center mb-16 animate-on-scroll">Programmes by Level</h2>

      <div class="space-y-12">
        {[
          {
            level: "Early Years", grades: "Pre-Nursery & Nursery | Ages 2 to 5",
            description: "Our early years programme is inspired by the Montessori method, creating a warm and stimulating environment where young children develop essential skills through guided play, structured activities, and age-appropriate learning experiences.",
            tags: ["Phonics & Early Literacy", "Numeracy Foundations", "Creative Play", "Social Development", "Motor Skills", "Music & Movement"],
            image: "fcs/uploads/ed5x9si0dgskgq27vlj8", accent: "border-l-green-400 bg-green-50/30",
          },
          {
            level: "Primary School", grades: "Basic 1 to 6 | Ages 6 to 11",
            description: "Our primary programme builds strong foundations in literacy, numeracy, sciences, and the arts. Following the NERDC curriculum, students develop critical thinking, communication skills, and a broad knowledge base.",
            tags: ["English Language", "Mathematics", "Basic Science", "Social Studies", "ICT", "Christian Studies", "Creative Arts", "Physical Education"],
            image: "fcs/uploads/ycpq35in1bqh04egavso", accent: "border-l-blue-400 bg-blue-50/30",
          },
          {
            level: "Junior Secondary", grades: "JSS 1 to 3 | Ages 12 to 14",
            description: "At the junior secondary level, students experience an expanded academic programme that includes practical laboratory work, advanced ICT training, and exposure to a broader range of subjects preparing them for BECE.",
            tags: ["Sciences", "Mathematics", "English", "Social Studies", "ICT", "Technical Drawing", "Home Economics", "Lab Practicals"],
            image: "fcs/uploads/w4cdwl4rqereeclyzocq", accent: "border-l-purple-400 bg-purple-50/30",
          },
          {
            level: "Senior Secondary", grades: "SSS 1 to 3 | Ages 15 to 17",
            description: "Our senior secondary programme offers specialised academic tracks in Science, Arts, and Commercial streams. Students are prepared for WAEC, NECO, and Cambridge IGCSE/A-Level examinations with dedicated support.",
            tags: ["WAEC Preparation", "NECO Preparation", "Cambridge IGCSE", "A-Levels", "Science Track", "Arts Track", "Commercial Track", "Career Guidance"],
            image: "fcs/uploads/fh0hylkx1mv6oozzq33h", accent: "border-l-amber-400 bg-amber-50/30",
          },
        ].map(item => (
          <div class={`bg-white rounded-2xl shadow-warm overflow-hidden border-l-4 ${item.accent} animate-on-scroll`}>
            <div class="flex flex-col md:flex-row">
              <img
                src={`https://res.cloudinary.com/dgvktekep/image/upload/w_500,h_400,c_fill,q_auto,f_auto/${item.image}.jpg`}
                alt={`${item.level} students at Faith Christian Schools`}
                class="w-full md:w-80 h-64 md:h-auto object-cover shrink-0"
                loading="lazy"
              />
              <div class="p-8 md:p-10">
                <h3 class="font-heading font-bold text-2xl text-maroon mb-1">{item.level}</h3>
                <p class="text-gold font-medium text-sm mb-4">{item.grades}</p>
                <p class="text-text-light leading-relaxed mb-4">{item.description}</p>
                <div class="flex flex-wrap gap-2">
                  {item.tags.map(tag => (
                    <span class="px-3 py-1 bg-cream rounded-full text-xs font-medium text-text-light border border-cream-dark">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
