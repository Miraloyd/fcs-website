---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Scholarships & Financial Aid" description="Learn about scholarship opportunities and financial aid options at Faith Christian Schools Karu.">
  <Header slot="header" />

  <PageHero title="Scholarships & Financial Aid" breadcrumb="Scholarships" />

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <h2 class="section-title">Investing in Potential</h2>
        <p class="section-subtitle">
          Faith Christian Schools believes that financial constraints should not be a barrier to quality education. We offer scholarship opportunities and flexible payment arrangements for qualifying families.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        <div class="p-8 rounded-2xl bg-cream-light border border-cream-dark">
          <div class="w-12 h-12 rounded-xl bg-gold flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-maroon mb-3">Academic Merit Scholarships</h3>
          <p class="text-text-light leading-relaxed mb-4">
            Outstanding students who demonstrate exceptional academic performance may qualify for partial or full tuition scholarships. These are awarded based on entrance examination results and ongoing academic achievement.
          </p>
          <ul class="space-y-2 text-sm text-text-light">
            <li class="flex items-start gap-2"><span class="text-gold font-bold">·</span> Based on entrance exam performance</li>
            <li class="flex items-start gap-2"><span class="text-gold font-bold">·</span> Renewable based on continued excellence</li>
            <li class="flex items-start gap-2"><span class="text-gold font-bold">·</span> Available across all education levels</li>
          </ul>
        </div>

        <div class="p-8 rounded-2xl bg-cream-light border border-cream-dark">
          <div class="w-12 h-12 rounded-xl bg-maroon flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-maroon mb-3">Sibling Discounts</h3>
          <p class="text-text-light leading-relaxed mb-4">
            Families with multiple children enrolled at Faith Christian Schools may qualify for sibling discounts, making quality education more accessible for the whole family.
          </p>
          <ul class="space-y-2 text-sm text-text-light">
            <li class="flex items-start gap-2"><span class="text-gold font-bold">·</span> Applicable from the second child</li>
            <li class="flex items-start gap-2"><span class="text-gold font-bold">·</span> Discount increases with additional siblings</li>
            <li class="flex items-start gap-2"><span class="text-gold font-bold">·</span> Enquire at the school office for details</li>
          </ul>
        </div>
      </div>

      <!-- How to Apply -->
      <div class="bg-gradient-to-r from-maroon to-maroon-dark rounded-3xl p-8 md:p-12 text-center">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-4">Enquire About Financial Aid</h2>
        <p class="text-white/80 mb-8 max-w-2xl mx-auto">
          For information about available scholarships, payment plans, and financial aid options, kindly contact our admissions office. We are committed to working with families to make quality education accessible.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="tel:+2348033406414"
            class="inline-flex items-center justify-center px-8 py-3.5 bg-gold text-maroon-dark font-semibold rounded-lg hover:bg-gold-light transition-colors"
          >
            Call Admissions
          </a>
          <a
            href={`${base}contact/`}
            class="inline-flex items-center justify-center px-8 py-3.5 border-2 border-white/30 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors"
          >
            Send an Enquiry
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
