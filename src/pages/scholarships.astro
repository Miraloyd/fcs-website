---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Scholarships & Financial Aid" description="Learn about scholarship opportunities and financial aid options at Faith Christian Schools Karu.">
  <Header slot="header" />

  <PageHero title="Scholarships & Financial Aid" breadcrumb="Scholarships" backgroundImage="fcs/uploads/fxqel12kgzqvv7b1ccgw" />

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16 animate-on-scroll">
        <h2 class="section-title">Investing in Potential</h2>
        <p class="section-subtitle">
          Faith Christian Schools believes that financial constraints should not be a barrier to quality education. We offer scholarship opportunities and flexible payment arrangements.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16 stagger-children">
        <div class="bg-cream-light rounded-2xl overflow-hidden shadow-warm card-hover">
          <img
            src="https://res.cloudinary.com/dgvktekep/image/upload/w_800,h_300,c_fill,q_auto,f_auto/fcs/uploads/jeeo7e0ffjfbbn71xqvo.jpg"
            alt="Academic excellence at Faith Christian Schools"
            class="w-full h-48 object-cover"
            loading="lazy"
          />
          <div class="p-8">
            <h3 class="font-heading font-bold text-xl text-maroon mb-3">Academic Merit Scholarships</h3>
            <p class="text-text-light leading-relaxed mb-4">
              Outstanding students who demonstrate exceptional academic performance may qualify for partial or full tuition scholarships based on entrance examination results.
            </p>
            <ul class="space-y-2 text-sm text-text-light">
              <li class="flex items-start gap-2"><span class="w-2 h-2 rounded-full bg-gold mt-2 shrink-0"></span> Based on entrance exam performance</li>
              <li class="flex items-start gap-2"><span class="w-2 h-2 rounded-full bg-gold mt-2 shrink-0"></span> Renewable based on continued excellence</li>
              <li class="flex items-start gap-2"><span class="w-2 h-2 rounded-full bg-gold mt-2 shrink-0"></span> Available across all education levels</li>
            </ul>
          </div>
        </div>

        <div class="bg-cream-light rounded-2xl overflow-hidden shadow-warm card-hover">
          <img
            src="https://res.cloudinary.com/dgvktekep/image/upload/w_800,h_300,c_fill,q_auto,f_auto/fcs/uploads/qz9las7rxmcljp8ka9bl.jpg"
            alt="Students and staff at Faith Christian Schools"
            class="w-full h-48 object-cover"
            loading="lazy"
          />
          <div class="p-8">
            <h3 class="font-heading font-bold text-xl text-maroon mb-3">Sibling Discounts</h3>
            <p class="text-text-light leading-relaxed mb-4">
              Families with multiple children enrolled may qualify for sibling discounts, making quality education more accessible for the whole family.
            </p>
            <ul class="space-y-2 text-sm text-text-light">
              <li class="flex items-start gap-2"><span class="w-2 h-2 rounded-full bg-gold mt-2 shrink-0"></span> Applicable from the second child</li>
              <li class="flex items-start gap-2"><span class="w-2 h-2 rounded-full bg-gold mt-2 shrink-0"></span> Discount increases with additional siblings</li>
              <li class="flex items-start gap-2"><span class="w-2 h-2 rounded-full bg-gold mt-2 shrink-0"></span> Enquire at the school office for details</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- CTA with Photo Background -->
      <div class="relative rounded-3xl overflow-hidden animate-on-scroll">
        <img
          src="https://res.cloudinary.com/dgvktekep/image/upload/w_1920,h_600,c_fill,q_auto,f_auto/fcs/uploads/friffapsxjid9ik8id81.jpg"
          alt="Campus life"
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-maroon-dark/90 via-maroon/85 to-maroon-dark/80"></div>
        <div class="relative z-10 p-8 md:p-16 text-center">
          <h2 class="text-2xl md:text-4xl font-heading font-bold text-white mb-4">Enquire About Financial Aid</h2>
          <p class="text-white/80 mb-8 max-w-2xl mx-auto text-lg">
            For information about available scholarships, payment plans, and financial aid options, kindly contact our admissions office.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="tel:+2348033406414"
              class="inline-flex items-center justify-center px-8 py-4 bg-gold text-maroon-dark font-bold rounded-xl hover:bg-gold-light transition-colors shadow-lg"
            >
              Call Admissions
            </a>
            <a
              href={`${base}contact/`}
              class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/40 text-white font-semibold rounded-xl hover:bg-white/10 transition-colors"
            >
              Send an Enquiry
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
