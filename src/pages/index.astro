---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home" description="Faith Christian Schools, Karu -- Quality education rooted in Christian values. Pre-Nursery through Senior Secondary. Cambridge and NERDC curriculum since 2003.">
  <Header slot="header" />

  <!-- HERO -->
  <Hero
    title="Where Faith Meets Excellence in Education"
    subtitle="Since 2003, Faith Christian Schools has been nurturing young minds with a curriculum that blends strong academic standards with enduring Christian values."
    backgroundImage="fcs/uploads/am9ovrwzhcuunye65pvt"
  />

  <!-- STATS BAR -->
  <section class="relative -mt-12 z-20 pb-8">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-2xl shadow-warm-lg p-8 grid grid-cols-2 md:grid-cols-4 gap-8 animate-on-scroll scale-in">
        <div class="text-center">
          <p class="text-[27px] md:text-[36px] font-heading font-bold text-maroon">20+</p>
          <p class="text-text-muted text-[12px] mt-1">Years of Excellence</p>
        </div>
        <div class="text-center">
          <p class="text-[27px] md:text-[36px] font-heading font-bold text-maroon">4</p>
          <p class="text-text-muted text-[12px] mt-1">Education Levels</p>
        </div>
        <div class="text-center">
          <p class="text-[27px] md:text-[36px] font-heading font-bold text-gold">2</p>
          <p class="text-text-muted text-[12px] mt-1">Curricula (NERDC + Cambridge)</p>
        </div>
        <div class="text-center">
          <p class="text-[27px] md:text-[36px] font-heading font-bold text-maroon">9</p>
          <p class="text-text-muted text-[12px] mt-1">Modern Facilities</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE US: Zigzag Sections -->
  <section class="py-20 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <h2 class="section-title">Why Choose Faith Christian Schools</h2>
        <p class="section-subtitle mx-auto">
          We integrate strong academic standards with Christian values to deliver quality, relevant education.
        </p>
      </div>

      <!-- Zigzag 1: Dual Curriculum (Image Left, Text Right) -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-20">
        <div class="animate-on-scroll slide-left">
          <div class="rounded-2xl overflow-hidden shadow-warm-lg">
            <img
              src="https://res.cloudinary.com/dgvktekep/image/upload/w_800,h_600,c_fill,q_auto,f_auto/fcs/uploads/jw3u1zfp6xjeosj84uvp.jpg"
              alt="Students in science laboratory at Faith Christian Schools"
              class="w-full h-80 object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="animate-on-scroll slide-right">
          <span class="text-gold font-semibold text-sm uppercase tracking-widest">Academics</span>
          <h3 class="text-xl md:text-2xl font-heading font-bold text-maroon mt-2 mb-4">Dual Curriculum for Global Readiness</h3>
          <p class="text-text-light leading-relaxed mb-6">
            Nigerian Curriculum (NERDC) combined with Cambridge International programmes (IGCSE/A-Levels), preparing students for both WAEC/NECO and international qualifications. Our graduates are equipped for universities in Nigeria and worldwide.
          </p>
          <a href={`${base}academics/`} class="inline-flex items-center text-maroon font-semibold hover:text-gold transition-colors">
            Explore Our Curriculum
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
        </div>
      </div>

      <!-- Zigzag 2: Christian Foundation (Text Left, Image Right) -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-20">
        <div class="order-2 lg:order-1 animate-on-scroll slide-left">
          <span class="text-gold font-semibold text-sm uppercase tracking-widest">Values</span>
          <h3 class="text-xl md:text-2xl font-heading font-bold text-maroon mt-2 mb-4">Rooted in Christian Values</h3>
          <p class="text-text-light leading-relaxed mb-6">
            Our nurturing environment develops character, integrity, and purpose alongside academic excellence. Through weekly chapel services, Bible study groups, and prayer meetings, we build a strong moral foundation that stays with our students for life.
          </p>
          <a href={`${base}about/`} class="inline-flex items-center text-maroon font-semibold hover:text-gold transition-colors">
            Learn About Our Values
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
        </div>
        <div class="order-1 lg:order-2 animate-on-scroll slide-right">
          <div class="rounded-2xl overflow-hidden shadow-warm-lg">
            <img
              src="https://res.cloudinary.com/dgvktekep/image/upload/w_800,h_600,c_fill,q_auto,f_auto/fcs/uploads/c5va6b40fngpoubsgujx.jpg"
              alt="Chapel and worship at Faith Christian Schools"
              class="w-full h-80 object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>

      <!-- Zigzag 3: Modern Facilities (Image Left, Text Right) -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="animate-on-scroll slide-left">
          <div class="rounded-2xl overflow-hidden shadow-warm-lg">
            <img
              src="https://res.cloudinary.com/dgvktekep/image/upload/w_800,h_600,c_fill,q_auto,f_auto/fcs/uploads/omafigywdykbu8udx6sc.jpg"
              alt="Computer lab and ICT training at Faith Christian Schools"
              class="w-full h-80 object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="animate-on-scroll slide-right">
          <span class="text-gold font-semibold text-sm uppercase tracking-widest">Facilities</span>
          <h3 class="text-xl md:text-2xl font-heading font-bold text-maroon mt-2 mb-4">Modern Facilities for Modern Learning</h3>
          <p class="text-text-light leading-relaxed mb-6">
            Science laboratory, computer/ICT room, library, sports facilities, sick bay, CCTV security, and reliable power supply. Every facility is designed to create an environment where students can thrive.
          </p>
          <div class="flex flex-wrap gap-2">
            {["Science Lab", "ICT Room", "Library", "Sports Field", "Sick Bay", "CCTV", "Generator", "Playground", "School Bus"].map(facility => (
              <span class="px-3 py-1.5 bg-cream rounded-full text-xs font-medium text-maroon border border-cream-dark">
                {facility}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EDUCATION LEVELS with Photos -->
  <section class="py-20 bg-cream-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <h2 class="section-title">A Complete Educational Journey</h2>
        <p class="section-subtitle mx-auto">
          From Pre-Nursery to Senior Secondary -- we walk with your child every step of the way.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 stagger-children">
        {[
          {
            level: "Early Years",
            grades: "Pre-Nursery & Nursery",
            description: "Montessori-inspired early learning that builds curiosity and social skills in a nurturing environment.",
            image: "fcs/uploads/ed5x9si0dgskgq27vlj8",
            accent: "border-green-400",
          },
          {
            level: "Primary",
            grades: "Basic 1 -- 6",
            description: "Strong foundational education in literacy, numeracy, sciences, and arts using the Nigerian curriculum.",
            image: "fcs/uploads/ycpq35in1bqh04egavso",
            accent: "border-blue-400",
          },
          {
            level: "Junior Secondary",
            grades: "JSS 1 -- 3",
            description: "Broadened academic exposure with science labs, ICT, and preparation for BECE examinations.",
            image: "fcs/uploads/w4cdwl4rqereeclyzocq",
            accent: "border-purple-400",
          },
          {
            level: "Senior Secondary",
            grades: "SSS 1 -- 3",
            description: "Specialised tracks preparing students for WAEC, NECO, and Cambridge IGCSE/A-Level examinations.",
            image: "fcs/uploads/fh0hylkx1mv6oozzq33h",
            accent: "border-amber-400",
          },
        ].map(item => (
          <div class={`bg-white rounded-2xl overflow-hidden shadow-warm card-hover border-t-4 ${item.accent}`}>
            <img
              src={`https://res.cloudinary.com/dgvktekep/image/upload/w_600,h_400,c_fill,q_auto,f_auto/${item.image}.jpg`}
              alt={`${item.level} students at Faith Christian Schools`}
              class="w-full h-48 object-cover"
              loading="lazy"
            />
            <div class="p-6">
              <h3 class="font-heading font-bold text-xl text-maroon mb-1">{item.level}</h3>
              <p class="text-gold text-sm font-medium mb-3">{item.grades}</p>
              <p class="text-text-light text-sm leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERY PREVIEW -->
  <section class="py-20 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-12 animate-on-scroll">
        <div>
          <h2 class="section-title">Life at Our School</h2>
          <p class="section-subtitle mb-0">
            See the vibrant community that makes Faith Christian Schools special.
          </p>
        </div>
        <a href={`${base}gallery/`} class="mt-4 md:mt-0 inline-flex items-center text-maroon font-semibold hover:text-gold transition-colors shrink-0">
          View Full Gallery
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 stagger-children">
        {[
          { id: "fcs/uploads/friffapsxjid9ik8id81", alt: "Campus life at Faith Christian Schools", span: "md:col-span-1 md:row-span-2" },
          { id: "fcs/uploads/plvv7mxlvhtbl0tt6czk", alt: "Student assembly and morning devotion", span: "" },
          { id: "fcs/uploads/itsy4k2c9rsqofcbcuv2", alt: "Students in uniform", span: "" },
          { id: "fcs/uploads/ebwxxhulbatoigskczvp", alt: "Sports day competition", span: "" },
          { id: "fcs/uploads/nxohbzzkadamhmqpc7zq", alt: "Cultural day celebrations", span: "" },
          { id: "fcs/uploads/xnzmpsufhviod5qnosn9", alt: "Students celebrating achievement", span: "" },
        ].map((image, i) => (
          <div class={`group relative rounded-2xl overflow-hidden ${i === 0 ? 'md:row-span-2' : ''}`}>
            <img
              src={`https://res.cloudinary.com/dgvktekep/image/upload/w_600,h_${i === 0 ? '900' : '450'},c_fill,q_auto,f_auto/${image.id}.jpg`}
              alt={image.alt}
              class={`w-full ${i === 0 ? 'h-full min-h-[300px]' : 'h-56'} object-cover transition-transform duration-500 group-hover:scale-105`}
              loading="lazy"
            />
            <div class="absolute inset-0 bg-maroon/0 group-hover:bg-maroon/30 transition-colors duration-300 flex items-end">
              <p class="text-white text-sm font-medium p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                {image.alt}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS PREVIEW -->
  <section class="py-20 bg-cream-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <h2 class="section-title">What Parents Say</h2>
        <p class="section-subtitle mx-auto">
          The voices of our community speak to the impact of a Faith Christian Schools education.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        {[
          {
            quote: "Faith Christian Schools has been a blessing for our family. The teachers are dedicated, the environment is safe, and our children are thriving both academically and spiritually.",
            role: "Primary School Parent",
          },
          {
            quote: "The combination of Nigerian and Cambridge curriculum gives our children an edge. They are not just prepared for WAEC -- they are prepared for the world.",
            role: "Secondary School Parent",
          },
          {
            quote: "The values I learnt at Faith Christian Schools -- integrity, hard work, and faith -- have stayed with me throughout my university education and career.",
            role: "FCS Graduate",
          },
        ].map(item => (
          <div class="bg-white p-8 rounded-2xl shadow-warm card-hover">
            <svg class="w-10 h-10 text-gold/40 mb-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <p class="text-text-light leading-relaxed mb-6 italic text-sm">
              "{item.quote}"
            </p>
            <p class="text-maroon font-semibold text-sm">{item.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ADMISSION CTA with Photo Background -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://res.cloudinary.com/dgvktekep/image/upload/w_1920,h_800,c_fill,q_auto,f_auto/fcs/uploads/b69gxyrqhsw5x3mt3amj.jpg"
        alt="Faith Christian Schools campus"
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-maroon-dark/90 via-maroon/85 to-maroon-dark/80"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <h2 class="text-[24px] md:text-[27px] font-heading font-bold text-white mb-6">
        Begin Your Child's Journey With Us
      </h2>
      <p class="text-white/80 text-lg leading-relaxed mb-10 max-w-2xl mx-auto">
        Admissions are open for the new academic session. Visit us to learn more about our programmes, meet our staff, and see our facilities firsthand.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}admissions/`}
          class="inline-flex items-center justify-center px-10 py-4 bg-gold text-maroon-dark font-bold rounded-xl hover:bg-gold-light transition-all duration-200 shadow-lg shadow-gold/30 text-lg"
        >
          Learn About Admissions
        </a>
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center px-10 py-4 border-2 border-white/40 text-white font-semibold rounded-xl hover:bg-white/10 transition-all duration-200 text-lg"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <!-- CONTACT STRIP -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center stagger-children">
        <div class="p-6 rounded-2xl bg-cream-light card-hover">
          <div class="w-14 h-14 rounded-xl bg-maroon/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-maroon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-maroon mb-2">Visit Us</h3>
          <p class="text-text-light text-sm">Plot MF 31, ABG Hill, Behind Water Board, Karu, FCT</p>
        </div>
        <div class="p-6 rounded-2xl bg-cream-light card-hover">
          <div class="w-14 h-14 rounded-xl bg-maroon/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-maroon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-maroon mb-2">Call Us</h3>
          <p class="text-text-light text-sm">
            <a href="tel:+2348036012387" class="hover:text-maroon transition-colors">+234 803 601 2387</a>
            <br />
            <a href="tel:+2348033406414" class="hover:text-maroon transition-colors">+234 803 340 6414</a> (Admissions)
          </p>
        </div>
        <div class="p-6 rounded-2xl bg-cream-light card-hover">
          <div class="w-14 h-14 rounded-xl bg-maroon/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-maroon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-maroon mb-2">Email Us</h3>
          <p class="text-text-light text-sm">
            <a href="mailto:info@faithchristianschools.net" class="hover:text-maroon transition-colors">info@faithchristianschools.net</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
