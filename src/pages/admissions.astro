---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Admissions" description="Apply to Faith Christian Schools Karu. Learn about our admission process, requirements, and how to enrol your child.">
  <Header slot="header" />

  <PageHero title="Admissions" breadcrumb="Admissions" />

  <!-- Admission Process -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <h2 class="section-title">Admission Process</h2>
        <p class="section-subtitle">
          We welcome families who share our commitment to academic excellence and Christian values. Our admission process is designed to be straightforward and supportive.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          {
            step: "1",
            title: "Visit the School",
            description: "Schedule a visit to tour our facilities, meet our staff, and learn about our programmes. We welcome walk-in visits during school hours.",
            icon: "🏫",
          },
          {
            step: "2",
            title: "Collect Forms",
            description: "Obtain the admission forms from the school office. Our administrative staff will guide you through the required documents.",
            icon: "📋",
          },
          {
            step: "3",
            title: "Entrance Assessment",
            description: "Your child will sit for an age-appropriate entrance examination, followed by an interview to assess readiness and placement level.",
            icon: "✍️",
          },
          {
            step: "4",
            title: "Complete Enrolment",
            description: "Upon successful assessment, complete the enrolment by paying school fees and submitting all required documentation.",
            icon: "✅",
          },
        ].map(item => (
          <div class="relative">
            <div class="bg-cream-light rounded-2xl p-8 border border-cream-dark h-full">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-maroon text-white flex items-center justify-center font-bold text-sm">
                  {item.step}
                </div>
                <span class="text-2xl">{item.icon}</span>
              </div>
              <h3 class="font-heading font-bold text-lg text-maroon mb-3">{item.title}</h3>
              <p class="text-text-light text-sm leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Requirements -->
  <section class="py-20 bg-cream-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="section-title">Requirements</h2>
          <p class="section-subtitle">
            Kindly prepare the following documents for the admission process.
          </p>
          <ul class="space-y-4">
            {[
              "Completed admission form",
              "Birth certificate or age declaration",
              "Recent passport photographs (4 copies)",
              "Previous school report card (for transfer students)",
              "Immunisation records",
              "Parent/guardian identification",
            ].map(item => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-text-light">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h2 class="section-title">Fees Information</h2>
          <p class="section-subtitle">
            For detailed information about our fee structure, kindly contact the school directly.
          </p>
          <div class="bg-white p-8 rounded-2xl border border-cream-dark">
            <p class="text-text-light leading-relaxed mb-6">
              Our fees cover tuition, textbooks, and access to all school facilities. We believe in transparent pricing and are happy to discuss fee details and payment options during your visit.
            </p>
            <div class="space-y-4">
              <a
                href="tel:+2348033406414"
                class="flex items-center gap-3 px-5 py-3 bg-maroon text-white rounded-lg hover:bg-maroon-dark transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                Call Admissions: +234 803 340 6414
              </a>
              <a
                href="https://wa.me/2349113224179"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 px-5 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                Chat on WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
