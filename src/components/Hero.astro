---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
  showMotto?: boolean;
  backgroundImage?: string;
}

const base = import.meta.env.BASE_URL;
const {
  title,
  subtitle,
  ctaText = "Apply Now",
  ctaHref = `${base}admissions/`,
  secondaryText = "Explore Academics",
  secondaryHref = `${base}academics/`,
  showMotto = true,
  backgroundImage = "fcs/uploads/am9ovrwzhcuunye65pvt",
} = Astro.props;

const bgUrl = `https://res.cloudinary.com/dgvktekep/image/upload/w_1920,h_1080,c_fill,q_auto,f_auto/${backgroundImage}.jpg`;
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background Photo with Ken Burns -->
  <div class="absolute inset-0">
    <img
      src={bgUrl}
      alt="Faith Christian Schools campus"
      class="w-full h-full object-cover kenburns"
      loading="eager"
      fetchpriority="high"
    />
    <!-- Dark Overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-maroon-dark/80 via-maroon/60 to-maroon-dark/70"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-20 md:pt-36 md:pb-28">
    <div class="max-w-3xl">
      {showMotto && (
        <p class="inline-block px-4 py-1.5 bg-gold/20 border border-gold/40 rounded-full text-gold font-heading italic text-sm md:text-base mb-6 tracking-wide animate-on-scroll">
          "Train up a child in the way he should go..." -- Proverbs 22:6
        </p>
      )}

      <h1 class="text-[27px] md:text-[33px] lg:text-[36px] font-heading font-bold text-white leading-[1.15] mb-6 animate-on-scroll">
        {title}
      </h1>

      {subtitle && (
        <p class="text-base md:text-lg text-white/85 leading-relaxed mb-8 max-w-2xl animate-on-scroll">
          {subtitle}
        </p>
      )}

      <div class="flex flex-col sm:flex-row gap-4 animate-on-scroll">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center px-8 py-4 bg-gold text-maroon-dark font-bold rounded-xl hover:bg-gold-light transition-all duration-200 shadow-lg shadow-gold/30 text-lg"
        >
          {ctaText}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href={secondaryHref}
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/40 text-white font-semibold rounded-xl hover:bg-white/10 transition-all duration-200 text-lg"
        >
          {secondaryText}
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
