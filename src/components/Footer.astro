---
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="bg-maroon-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Column 1: School Info -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img
            src="https://res.cloudinary.com/dgvktekep/image/upload/w_48,h_48,c_fill,q_auto,f_auto/v1770294148/fcs/uploads/xxe18ouwcljc86y4wloy.jpg"
            alt="FCS Logo"
            class="w-10 h-10 rounded-full object-cover ring-2 ring-white/20"
            width="40"
            height="40"
          />
          <span class="font-heading font-bold text-lg">Faith Christian Schools</span>
        </div>
        <p class="text-white/70 text-sm leading-relaxed mb-4">
          Quality education rooted in Christian values since 2003. Nurturing young minds in Karu, FCT.
        </p>
        <p class="text-white/50 text-xs italic font-heading">
          "Train up a child in the way he should go..."
          <br />-- Proverbs 22:6
        </p>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {[
            { href: `${base}about/`, label: "About Us" },
            { href: `${base}academics/`, label: "Academics" },
            { href: `${base}admissions/`, label: "Admissions" },
            { href: `${base}student-life/`, label: "Student Life" },
            { href: `${base}gallery/`, label: "Gallery" },
            { href: `${base}testimonials/`, label: "Testimonials" },
            { href: `${base}scholarships/`, label: "Scholarships" },
            { href: `${base}news/`, label: "News & Events" },
            { href: `${base}contact/`, label: "Contact Us" },
          ].map(link => (
            <li>
              <a href={link.href} class="text-white/70 text-sm hover:text-gold transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Contact -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-4">Contact Us</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-white/70">Plot MF 31, ABG Hill,<br />Behind Water Board, Karu, FCT</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+2348036012387" class="text-white/70 hover:text-gold transition-colors">+234 803 601 2387</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@faithchristianschools.net" class="text-white/70 hover:text-gold transition-colors">info@faithchristianschools.net</a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Social + WhatsApp -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-4">Connect With Us</h3>
        <div class="space-y-3">
          <a
            href="https://wa.me/2349113224179"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2.5 bg-green-600 rounded-lg hover:bg-green-700 transition-colors text-sm font-medium"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            Chat on WhatsApp
          </a>
          <a
            href="https://www.facebook.com/share/p/1AMWrKZjMS/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-white/70 hover:text-gold transition-colors text-sm"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Follow on Facebook
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/50 text-xs">
        &copy; {currentYear} Faith Christian Schools, Karu. All rights reserved.
      </p>
      <p class="text-white/40 text-xs">
        Designed by <a href="https://miraloyd.com" target="_blank" rel="noopener noreferrer" class="text-gold/60 hover:text-gold transition-colors">Miraloyd Global Consult</a>
      </p>
    </div>
  </div>
</footer>
