---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About Us" },
  { href: "/academics", label: "Academics" },
  { href: "/admissions", label: "Admissions" },
  { href: "/student-life", label: "Student Life" },
  { href: "/gallery", label: "Gallery" },
  { href: "/news", label: "News" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-cream-dark sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo + School Name -->
      <a href="/" class="flex items-center gap-3 group">
        <img
          src="https://res.cloudinary.com/dgvktekep/image/upload/w_60,h_60,c_fill,q_auto,f_auto/v1770294148/fcs/uploads/xxe18ouwcljc86y4wloy.jpg"
          alt="Faith Christian Schools Logo"
          class="w-12 h-12 rounded-full object-cover ring-2 ring-maroon/20"
          width="48"
          height="48"
        />
        <div>
          <span class="text-maroon font-heading font-bold text-lg leading-tight block">Faith Christian Schools</span>
          <span class="text-text-muted text-xs tracking-wide">Karu, FCT</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              "px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-200",
              currentPath === link.href
                ? "bg-maroon text-white"
                : "text-text hover:bg-cream hover:text-maroon"
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA Button -->
      <a
        href="/admissions"
        class="hidden lg:inline-flex items-center px-5 py-2.5 bg-maroon text-white text-sm font-semibold rounded-lg hover:bg-maroon-dark transition-colors duration-200"
      >
        Apply Now
      </a>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg text-text hover:bg-cream"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-cream-dark">
    <nav class="px-4 py-4 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            "block px-4 py-3 rounded-lg text-sm font-medium transition-colors",
            currentPath === link.href
              ? "bg-maroon text-white"
              : "text-text hover:bg-cream hover:text-maroon"
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/admissions"
        class="block px-4 py-3 mt-2 bg-maroon text-white text-sm font-semibold rounded-lg text-center hover:bg-maroon-dark transition-colors"
      >
        Apply Now
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
